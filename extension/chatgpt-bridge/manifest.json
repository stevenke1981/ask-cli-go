{
  "manifest_version": 3,
  "name": "ask-cli ChatGPT Bridge",
  "description": "Connects ask-cli to the authenticated ChatGPT page in regular Chrome.",
  "version": "0.1.0",
  "permissions": [],
  "host_permissions": [
    "https://chatgpt.com/*",
    "http://127.0.0.1/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
